@model TiendaMVC.Models.Producto
@using TiendaMVC.Models
<h2>Nuevo Producto</h2>
<form method="post">
    <label>Nombre:</label><br />
    <input name="Nombre" required /><br /><br />

    <label>Precio:</label><br />
    <input name="Precio" type="number" step="0.01" required /><br /><br />

    <label>Stock:</label><br />
    <input name="Stock" type="number" required /><br /><br />

    <label>Categoría:</label><br />
    <select name="CategoriaId" required>
        <option value="">-- Selecciona --</option>
        @foreach (Categoria c in ViewBag.Categorias)
        {
            <option value="@c.Id">@c.Nombre</option>
        }
    </select><br /><br />

    <button type="submit">Guardar</button>
    <a href="/Productos">Cancelar</a>
</form>